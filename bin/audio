#!/usr/bin/env fish
# -----
# title:    audioselect
# author:   emil lenz
# email:    emillenz@protonmail.com
# date:     2023-08-07
# -----

function main
    set -l icon "󱀞"
    set -l sinks (pactl --format json list sinks)
    set -l choice (echo $sinks | jq '.[] | .description' | rofi -dmenu -i -no-custom -p "$icon  audio >" )
    if test -z $choice
        exit 1
    end
    set -l sink (echo $sinks | jq ".[] | select(.description == $choice) | .name")
    pactl set-default-sink $sink

    set -l sink_ids (pactl -f json list sink-inputs | jq ".[] | .index")
    for id in $sink_ids
        pactl move-sink-input $id $sink
    end
    dunstify "$icon  audio" "changed output\n$choice"
end

main
