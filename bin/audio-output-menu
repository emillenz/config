#!/usr/bin/env ruby
# ---
# title:  audio output selection menu
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-05-07
# dependencies: rofi, pamixer, dunst
# ---

require 'json'

DMENU = 'dmenu -b -i -fn "Iosevka Nerd Font-10" -nb "#ffffff" -nf "#000000" -sb "#c0deff" -sf "#000000"'.freeze

def main
        sinks = JSON.parse(`pactl --format json list sinks`)

        dmenu_in= sinks.map { |sink| sink['description'] }.join("\n")
        sink_sel = `echo "#{dmenu_in}" | #{DMENU} -p "audio-output > "`.strip
        exit 1 if sink_sel == ''

        sink_id = sinks.find { |s| s['description'] == sink_sel }['index']
        `pactl set-default-sink #{sink_id}`

        JSON.parse(`pactl --format json list sink-inputs`).map do |sink|
                `pactl move-sink-input #{sink['index']} #{sink_id}`
        end

        `dunstify "#{icon}  audio-output" "changed output device\n#{choice}"`
end

main if __FILE__ == $PROGRAM_NAME
