#!/usr/bin/env fish
# ---
# title:  autostart
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-08-08
# ---

function main
    set -l pss \
        playerctld \
        "alacritty --class cmd --title cmd --command tmux new-session -A -s cmd" \
        "emacs --daemon && emacsclient --reuse-frame" \
        unclutter \
        "batsignal -bpe -w 50 -c 20 -d 5" \
        firefox \
        keepassxc

    for ps in $pss
        if pgrep (echo $ps | string split -f1 ' ') >/dev/null
            printf "running :: %s\n" $ps
        else
            fish --command $ps &>/dev/null &
            printf "started :: %s\n" $ps
        end
    end
    if not pgrep xremap >/dev/null
        sudo xremap --watch=device ~/.config/xremap/config.yml &>/dev/null &
    end

    xsetroot -solid '#ffffff'
    xset dpms 0 0 0 && xset s off # never screensave / turn screen off (do manually if needed)
    xset r off &
end

main
