#!/usr/bin/env ruby
# -----
# title:  autostart
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-05-07
# -----

def main
        processes = [
                'playerctld',
                'alacritty --title cmd --command tmux new-session -A -s cmd',
                'emacs --daemon && emacsclient --reuse-frame',
                'unclutter',
                'batsignal -bpe -w 50 -c 20 -d 5',
                'keepassxc',
                'firefox',
                'firefox --new-window https://chat.openai.com',
                'firefox --new-window https://spotify.com',
                'sudo xremap --watch=device ~/.config/xremap/config.yml'
        ]

        ps_data = `ps -e`.lines.drop(1)

        # get running ps names
        ps_running = ps_data.map do |line|
                line.split(/\s+/) [4..].join(' ').strip
        end

        processes.each do |prog|
                `#{prog} &>/dev/null & disown` unless ps_running.include?(prog.split[0])
        end

        `xsetroot -solid '#ffffff'`
        `xset dpms 0 0 0; xset s off`
        `sleep 1 && xset r off` # HACK: wait for xremap
end

main if __FILE__ == $PROGRAM_NAME
