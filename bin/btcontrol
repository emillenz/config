#!/usr/bin/env nu

# TODO pairing devices

const icon = ""

# -----
# title:  Bluetoothcontrol
# author: Emil Lenz
# email:  emillenz@protonmail.com
# date:   Saturday,  4 November, 2023
# info:   Conttrol the systems bluetooth
# -----
def main [] {
  let action = (prompt --keymenu $icon "Action: [c] connect | [d] disconnect" [c d])
  match $action {
    "c" => {
      bluetoothctl power on
      let devs = (bluetoothctl devices | lines | parse '{cat} {addr} {name}')
      let dev = (prompt $icon "" ($devs | get name))
      let dev_addr = ($devs | where name == $dev | get addr)
      bluetoothctl connect ($dev_addr)
    },
    "d" => {
      bluetoothctl power off
    },
  }
}

def prompt [
  --custom(-c),  # Let the user input custom text
  --keymenu(-k), # single char keymenu to select static items -> items must be a list of chars // the chars that are the start of each item mnemonically, display msg: `Choose: [a] anna | [b] bonnie | [c] chris | [C] clyde` and the letters [a b c C] as input
  name: string   # name of program/script (or better: icon)
  msg: string,   # msg to display before prompt
  input?: list,
] {
  if $custom {
    let ans = (rofi -dmenu -i -p $"($name) ($msg)" | str trim)
    if $ans == "" {
      print $"($name): exit by user"
      exit 0
    }
    return $ans
  } else if $keymenu {
    let ans = (
      $input |
      str join "\n" |
      rofi -dmenu -no-custom -auto-select -p $"($name) ($msg)" | # NOTE: case sensitive
      str trim
    )
    if $ans == "" {
      print $"($name): exit by user"
      exit 0
    }
    return $ans
  } else {
    let ans = (
      $input |
      str join "\n" |
      rofi -dmenu -i -no-custom -p $"($name) ($msg)" |
      str trim
    )
    if $ans == "" {
      print $"($name): exit by user"
      exit 0
    }
    return $ans
  }
}
