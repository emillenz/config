#!/usr/bin/env nu

use utils.nu

# -----
# title:  rofi menu to kill a running process.
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-08-08
# info:   kill a specific process by name using rofi
# -----
def main [] {
        let $icon = ""
        let ps = (utils rofi (ps | get name) "killprocess" $icon)
        sudo killall $ps
        dunstify $"($icon)  killprocess" $ps
}
