#!/usr/bin/env fish
# ---
# title:  rofi menu to kill a running process.
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-08-08
# ---

function main
    set -l icon ""
    set -l ps (ps -e | awk '{print $4}' | rofi -dmenu -i -no-custom -p "$icon  killprocess >")
    if test -z $ps
        exit 1
    end
    sudo killall $ps
    dunstify "$icon  killprocess" $ps
end

main
