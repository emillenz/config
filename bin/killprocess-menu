#!/usr/bin/env ruby
# ---
# title:  killprocess menu
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-05-08
# dependencies: dmenu, dunst
# ---

DMENU = 'dmenu -b -i -fn "Iosevka Nerd Font-10" -nb "#ffffff" -nf "#000000" -sb "#c0deff" -sf "#000000"'.freeze # NOTE :: modus vivendi theme

def main
        pss = `ps -e`.lines.drop(1).map do |line|
                columns = line.split(/\s+/)
                name = columns[4..].join(' ').strip
                pid = columns[1]
                [name, pid]
        end.to_h

        dmenu_in = pss.keys.join("\n")
        ps_sel = `echo "#{dmenu_in}" | #{DMENU} -p "killprocess > "`.strip
        exit 1 if ps_sel == ''
        ps_id = pss[ps_sel]

        `sudo kill #{ps_id}`
        `dunstify "#{icon}  killprocess" #{ps_sel}`
end

main if __FILE__ == $PROGRAM_NAME
