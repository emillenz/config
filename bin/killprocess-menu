#!/usr/bin/env ruby
# ---
# title:  killprocess menu
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-05-08
# dependencies: rofi, dunst
# ---

def main
        icon = ''

        pss = `ps -e`.lines.drop(1).map do |line|
                columns = line.split(/\s+/)
                name = columns[4..].join(' ').strip
                pid = columns[1]
                [name, pid]
        end.to_h

        rofi_opts = pss.keys.join("\n")
        ps_selected = `echo "#{rofi_opts}" | rofi -dmenu -i -no-custom -p "#{icon}  killprocess >"`.strip
        exit 1 if ps_selected == ''

        `sudo kill #{pss[ps_selected]}`
        `dunstify "#{icon}  killprocess" #{ps_selected}`
end

main if __FILE__ == $PROGRAM_NAME
