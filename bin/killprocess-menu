#!/usr/bin/env ruby
# ---
# title:  killprocess menu
# author: emil lenz
# email:  emillenz@protonmail.com
# date:   2023-05-08
# dependencies:
# - sh: dmenu
# - ruby gem: ruby-notify-send
# ---

require 'notify-send'
require 'open3'

DMENU_CMD = [
        'dmenu',
        '-b',
        '-i',
        '-fn', 'Iosevka Comfy-10',
        '-nb', '#ffffff',
        '-nf', '#000000',
        '-sb', '#c0deff',
        '-sf', '#000000',
        '-p',  'killprocess > '
].freeze

def main
        pss = `ps -e`.lines.drop(1).map do |line|
                columns = line.split(/\s+/)
                name = columns[4..].join(' ').strip
                pid = columns[1]
                [name, pid]
        end.to_h

        dmenu_stdin = pss.keys.join("\n")
        read, status = Open3.capture2(*DMENU_CMD, stdin_data: dmenu_stdin)
        exit 1 unless status.success?
        ps_id = pss[read.chomp]

        `sudo kill #{ps_id}`
        NotifySend.send('killprocess', read)
end

main if __FILE__ == $PROGRAM_NAME
