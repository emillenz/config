#!/usr/bin/env nu

# -----
# title:  Killprocess
# author: Emil Lenz
# email:  emillenz@protonmail.com
# date:   Tuesday, 8 August, 2023
# info:   Utility script using rofi, to kill a specific process by name.
# -----
def main [] {
  ~/.config/bin/remaps

  let start_ps = [
    "polybar",
    "nm-applet",
    "playerctld",
    "keepassxc",
    "syncthing",
    "tmux new-session -s 'cmd'"
    "emacs --bg-daemon --execute '(doom/reload)'",
  ]

  let pss = (ps | get name | each {split words | get 0})

  for p in $start_ps {
    let exists = (($p | split words | get 0) in $pss)
    if not $exists {
      $"($p) &>/dev/null &" | bash
    }
  }
}
