#!/usr/bin/env nu

# -----
# title:  Killprocess
# author: Emil Lenz
# email:  emillenz@protonmail.com
# date:   Tuesday, 8 August, 2023
# info:   Utility script using rofi, to kill a specific process by name.
# -----
def main [] {
  ~/.config/bin/remaps

  let start_ps = [
    "batsignal -b -w 50 -c 20 -d 5" # NOTE :: batterylevel's to notify at
    "nm-applet"
    "playerctld"
    "keepassxc"
    "syncthing"
    "tmux new-session -s 'cmd'"
    "emacs --bg-daemon"
    "unclutter"
    "xsetroot -solid '#002b36'" # solarized_dark: #002b36; solarized_light: #F2E6CE
    "xset dpms 0 0 0"
  ]

  let pss = (ps | get name | each {split words | get 0})

  for p in $start_ps {
    if not (($p | split words | get 0) in $pss) {
      $"($p) &>/dev/null &" | bash
    }
  }
}
