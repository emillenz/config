#!/usr/bin/env nu

# -----
# title:  Startup
# author: Emil Lenz
# email:  emillenz@protonmail.com
# date:   2023-08-08
# info:   All background processes and commands to be run at startup for the system.
# -----
def main [] {
  ~/.config/bin/remaps

  let start_ps = [
    "batsignal -b -f 98 -w 50 -c 20 -d 5",
    "udiskie"
    "nm-applet",
    "playerctld",
    "keepassxc",
    "syncthing",
    "tmux new-session -s 'cmd'",
    "emacs --bg-daemon",
    "unclutter",
    "xsetroot -solid '#002b36'", # solarized_dark bg
    "xset dpms 0 0 0",
    "xset s off",
  ]

  let pss = (ps | get name | each {split words | get 0})

  for p in $start_ps {
    if not (($p | split words | get 0) in $pss) {
      $"($p) &>/dev/null &" | bash
    }
  }
}
