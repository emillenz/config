#!/usr/bin/env nu

# -----
# title:  Startup
# author: Emil Lenz
# email:  emillenz@protonmail.com
# date:   2023-08-08
# info:   All background processes and commands to be run at startup for the system.
# -----
def main [] {
  let start_ps = [
    "sudo xremap --watch=device ~/.config/xremap/config.yml"
    "batsignal -b -f 95 -w 20 -c 10 -d 5"
    "playerctld"
    "keepassxc"
    "syncthing"
    "tmux new-session -s 'cmd'"
    "emacs --bg-daemon --eval='(doom/reload)'"
    "unclutter"
    "xsetroot -solid '#002b36'" # NOTE:: solarized_dark bg
    "xset dpms 0 0 0"
    "xset s off"
    "sleep 1; xset r off" # HACK :: wait for xremap
    "sleep 1; xkbset sticky -twokey -latchlock"
  ]

  let pss = (ps | get name | each {split words | get 0})

  for p in $start_ps {
    if not (($p | split words | get 0) in $pss) {
      $"($p) &>/dev/null &" | bash
    }
  }
}
