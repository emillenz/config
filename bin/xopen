#!/usr/bin/env nu

# -----
# title:  Xopen
# author: Emil Lenz
# email:  emillenz@protonmail.com
# date:   Saturday, 23 September, 2023
# info:   Find & open a file with the default program using rofi & fd.
#         Configure xdg-mime-types in order for the corrrect program to open the file.
# -----
def main [
  --extension(-e): string, # Filter based on extension (multiple supported)
] {
  let icon = ""
  mut file = ""
  if ($extension != null) {
    $file = (prompt $icon "" (fd --type file --extension $extension . ~ | lines | path relative-to ~))
  } else {
    $file = (prompt $icon "" (fd --type file . ~ | lines | path relative-to ~))
  }
  $"xdg-open '($file)' &>/dev/null &" | bash
}

def prompt [
  --custom(-c),  # Let the user input custom text
  --keymenu(-k), # single char keymenu to select static items -> items must be a list of chars // the chars that are the start of each item mnemonically, display msg: `Choose: [a] anna | [b] bonnie | [c] chris | [C] clyde` and the letters [a b c C] as input
  name: string   # name of program/script (or better: icon)
  msg: string,   # msg to display before prompt
  input?: list,
] {
  if $custom {
    let ans = (rofi -dmenu -i -p $"($name) ($msg)" | str trim)
    if $ans == "" {
      print $"($name): exit by user"
      exit 0
    }
    return $ans
  } else if $keymenu {
    let ans = (
      $input |
      str join "\n" |
      rofi -dmenu -no-custom -auto-select -p $"($name) ($msg)" | # NOTE: case sensitive
      str trim
    )
    if $ans == "" {
      print $"($name): exit by user"
      exit 0
    }
    return $ans
  } else {
    let ans = (
      $input |
      str join "\n" |
      rofi -dmenu -i -no-custom -p $"($name) ($msg)" |
      str trim
    )
    if $ans == "" {
      print $"($name): exit by user"
      exit 0
    }
    return $ans
  }
}
