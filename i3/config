# ALIASES
set $ROFI rofi -dmenu -i -no-custom -p
set $ESC ; mode "default"
set $EXIT bindsym Escape mode "default"
set $BIN ~/.config/bin
set $MV move container to workspace
set $MAP bindsym
set $CMD exec --no-startup-id
set $SCREENSHOT_FULL scrot '%Y-%m-%d_T%H-%M.png' -q 100 -e 'mv $f ~/Pictures/screenshots/' && dunstify "scrot" "saved in: ~/Pictures/screenshots"
set $SCREENSHOT_SEL scrot --select '%Y-%m-%d_T%H-%M.png' -q 100 -e 'mv $f ~/Pictures/screenshots/' && dunstify "scrot" "saved in: ~/Pictures/screenshots"
set $VOL_INC pamixer --unmute --increase 5 && dunstify --replace 69 "vol: $(pamixer --get-volume-human)"
set $VOL_DEC pamixer --unmute --decrease 5 && dunstify --replace 69 "vol: $(pamixer --get-volume-human)"
set $VOL_MUTE pamixer --toggle-mute && dunstify --replace 69 "vol: $(pamixer --get-volume-human)" $ESC
set $VOL_MIC_MUTE pamixer --default-source --toggle-mute && dunstify --replace 69 "mic-mute: $(pamixer --default-source --get-mute)" $ESC
set $SYS_SLEEP i3lock --color ffffff && systemctl suspend
set $SYS_SCREENOFF sleep 1 && xset dpms force off

# AUTOSTART
exec $BIN/autostart &

# OPTS
workspace_auto_back_and_forth no
workspace_layout tabbed
force_focus_wrapping yes
default_orientation horizontal
default_border pixel 2
hide_edge_borders smart
title_align left
font pango: Comic Code Ligatures 9
focus_on_window_activation focus

# KEYBINDINGS
set $MOD Mod1
floating_modifier $MOD
$MAP --release button2 kill
$MAP --whole-window $MOD+button2 floating toggle
# disable mousewheel function on titlebar (no accidental window switching)
$MAP button4 nop
$MAP button5 nop

$MAP XF86MonBrightnessDown $CMD brightnessctl set 5%-
$MAP XF86MonBrightnessUp   $CMD brightnessctl set 5%+
$MAP XF86Display           $CMD xrandr --auto
$MAP XF86ScreenSaver       $CMD $SYS_SCREENOFF
$MAP XF86Sleep             $CMD $SYS_SLEEP
$MAP XF86AudioPlay         $CMD playerctl play-pause
$MAP XF86AudioPause        $CMD playerctl play-pause
$MAP XF86AudioNext         $CMD playerctl next
$MAP XF86AudioPrev         $CMD playerctl previous
$MAP XF86AudioLowerVolume  $CMD $VOL_DEC
$MAP XF86AudioRaiseVolume  $CMD $VOL_INC
$MAP XF86AudioMute         $CMD $VOL_MUTE
$MAP XF86AudioMicMute      $CMD $VOL_MIC_MUTE

$MAP $MOD+9            $CMD $VOL_MIC_MUTE
$MAP $MOD+0            $CMD $VOL_MUTE
$MAP $MOD+minus        $CMD $VOL_DEC
$MAP $MOD+equal        $CMD $VOL_INC
$MAP $MOD+bracketright $CMD playerctl next
$MAP $MOD+bracketleft  $CMD playerctl previous
$MAP $MOD+backslash    $CMD playerctl play-pause

$MAP $MOD+l         focus next
$MAP $MOD+h         focus prev
$MAP $MOD+q         kill
$MAP $MOD+g         $CMD rofi -show window
$MAP $MOD+semicolon $CMD rofi -show drun
$MAP $MOD+s         layout toggle tabbed splith
$MAP $MOD+Return    move workspace to output next
$MAP $MOD+a         workspace back_and_forth

# WORKSPACES
for_window [urgent="latest"] focus
# random window -> 1
for_window [all] $MV 1, focus, title_window_icon no

set $WS_CMD "cmd"
workspace $WS_CMD output primary
$MAP $MOD+c workspace $WS_CMD
$MAP $MOD+shift+c $CMD alacritty --title cmd --command tmux new-session -A -s cmd $ESC
for_window [class="Alacritty"] $MV $WS_CMD, focus

set $WS_DOCS "docs"
workspace $WS_DOCS output primary
$MAP $MOD+d workspace $WS_DOCS
$MAP $MOD+shift+d $CMD xdg-open "$(fd --type file . ~ | $ROFI 'find-file')"
for_window [class="Zathura"] $MV $WS_DOCS, focus

set $WS_WEB "web"
workspace $WS_WEB output primary
$MAP $MOD+w workspace $WS_WEB
$MAP $MOD+shift+w $CMD firefox --new-window
for_window [class="firefox"] $MV $WS_WEB, focus

set $WS_EDIT "edit"
workspace $WS_EDIT output primary
$MAP $MOD+e workspace $WS_EDIT
$MAP $MOD+shift+e $CMD emacsclient --reuse-frame || emacs --daemon && emacsclient --reuse-frame
for_window [class="Emacs|Eclipse"] $MV $WS_EDIT, focus

# NOTE :: copy link to clipboard > open mpv with binding to view there
set $WS_VIDEO "video"
workspace $WS_VIDEO output primary
$MAP $MOD+v workspace $WS_VIDEO
$MAP $MOD+shift+v $CMD mpv "$(xclip -out)"
for_window [class="mpv"] $MV $WS_VIDEO, focus

set $WS_AI "ai"
workspace $WS_AI output primary
$MAP $MOD+i workspace $WS_AI
$MAP $MOD+shift+i $CMD firefox --new-window https://chat.openai.com
for_window [class="firefox" title="ChatGPT"] $MV $WS_AI, focus

set $WS_MUSIC "music"
workspace $WS_MUSIC output primary
$MAP $MOD+m workspace $WS_MUSIC
$MAP $MOD+shift+m $CMD firefox --new-window https://spotify.com
for_window [class="firefox" title="Spotify"] $MV $WS_MUSIC, focus

$MAP $MOD+1 workspace 1

$MAP $MOD+f mode "find-file"
mode "find-file" {
        $MAP $MOD+c $CMD xdg-open "$(fd --extension pdf . ~/Documents/uni/cs/s2 | $ROFI 'find [cs]')" $ESC
        $MAP $MOD+l $CMD xdg-open "$(fd . ~/Documents/literature/source | $ROFI 'find-file')" $ESC
        $MAP $MOD+f $CMD xdg-open "$(fd --type file . ~ | $ROFI 'find [all]')" $ESC
        $MAP $MOD+d $CMD xdg-open "$(fd --extension pdf . ~/Downloads | $ROFI 'find [downloads]')" $ESC
        $EXIT
}

$MAP $MOD+space mode "leader"
mode "leader" {
        $MAP $MOD+a           $CMD $BIN/audio-output-menu $ESC
        $MAP --release $MOD+s $CMD $SCREENSHOT_SEL $ESC
        $MAP $MOD+shift+s     $CMD $SCREENSHOT_FULL $ESC
        $MAP $MOD+k           $CMD $BIN/killprocess-menu $ESC
        $MAP $MOD+d           $CMD fd . ~/.screenlayout | $ROFI 'screen-layout' | sh $ESC
        $MAP $MOD+q           mode "quit"
        $EXIT
}

mode "quit" {
        $MAP $MOD+e                 $CMD i3-msg exit $ESC
        $MAP $MOD+q                 $CMD $SYS_SLEEP $ESC
        $MAP --release $MOD+shift+q $CMD systemctl poweroff $ESC
        $MAP $MOD+r                 $CMD i3-msg restart $ESC
        $MAP $MOD+shift+r           $CMD systemctl reboot $ESC
        $MAP $MOD+o                 $CMD $SYS_SCREENOFF $ESC
        $EXIT
}

# MODUS-VIVENDI THEME
set $BG          '#ffffff'
set $FG          #000000
set $MODELINE_BG #c8c8c8
set $BORDER      #9f9f9f
set $ACTIVE_BG   #c0deff
set $URGENT_FG   #7f0000

# element               $box       $bg          $fg $mark $border
client.focused          $ACTIVE_BG $ACTIVE_BG   $FG $FG   $ACTIVE_BG
client.focused_inactive $BORDER    $MODELINE_BG $FG $FG   $BORDER
client.unfocused        $BORDER    $MODELINE_BG $FG $FG   $BORDER
client.urgent           $URGENT_FG $URGENT_FG   $FG $FG   $URGENT_FG
client.background       $BG

# MODELINE
bar {
        mode hide
        hidden_state hide
        workspace_buttons no
        binding_mode_indicator yes
        modifier none
        tray_output primary
        status_command i3status
        separator_symbol " | "

        colors {
                background $MODELINE_BG
                statusline $FG
                separator  $FG
                # class      $border      $bg          $fg
                binding_mode $MODELINE_BG $MODELINE_BG $FG
        }
}
