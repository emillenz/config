# [[file:config.org::*Startup automation][Startup automation:1]]
exec --no-startup-id "~/.config/bin/startup"
# Startup automation:1 ends here

# [[file:config.org::*Options][Options:1]]
workspace_auto_back_and_forth no
workspace_layout tabbed
force_focus_wrapping no
default_orientation horizontal
default_border pixel 1
hide_edge_borders smart
title_align left
font pango: Terminus 8
focus_on_window_activation focus
# Options:1 ends here

# [[file:config.org::*Options][Options:2]]
set $rofi rofi -dmenu -i -no-custom -p ' '
# Options:2 ends here

# [[file:config.org::*Modkey][Modkey:1]]
set $mod Mod4
# Modkey:1 ends here

# [[file:config.org::*Mouse][Mouse:1]]
floating_modifier $mod
bindsym --release button2 kill
bindsym --whole-window $mod+button2 floating toggle
bindsym button4 nop
bindsym button5 nop
# Mouse:1 ends here

# [[file:config.org::*System controls][System controls:1]]
bindsym XF86MonBrightnessDown exec sudo light -U 5
bindsym XF86MonBrightnessUp   exec sudo light -A 5
bindsym XF86Display           exec ~/.config/bin/output_select
bindsym XF86ScreenSaver       exec xset dpms force off
bindsym XF86Sleep             exec i3lock -e --color 002b36 && systemctl suspend

bindsym XF86AudioPlay         exec playerctl play
bindsym XF86AudioPause        exec playerctl pause
bindsym XF86AudioNext         exec playerctl next
bindsym XF86AudioPrev         exec playerctl previous
bindsym XF86AudioRaiseVolume  exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume  exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute         exec pactl set-sink-mute @DEFAULT_SINK@ toggle
# System controls:1 ends here

# [[file:config.org::*System controls][System controls:2]]
bindsym Print                 exec ~/.config/bin/screenshot
bindsym $mod+backslash        exec playerctl play-pause
bindsym $mod+bracketright     exec playerctl next
bindsym $mod+bracketleft      exec playerctl previous
bindsym $mod+0                exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym $mod+equal            exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym $mod+minus            exec pactl set-sink-volume @DEFAULT_SINK@ -5%
# System controls:2 ends here

# [[file:config.org::*Core navigation][Core navigation:1]]
bindsym $mod+j          focus prev
bindsym $mod+shift+j    move left
bindsym $mod+k          focus next
bindsym $mod+shift+k    move right

bindsym $mod+q          kill
bindsym $mod+f          exec rofi -show drun
bindsym $mod+g          exec rofi -show window
bindsym $mod+semicolon  exec rofi -show run
bindsym $mod+Tab        layout toggle tabbed splith
bindsym $mod+Return     move workspace to output next
# bindsym $mod+m          exec i3-input -F 'mark %s' -l 1 -P 'Mark:'
# bindsym $mod+apostrophe exec i3-input -F '[con_mark="%s"] focus' -l 1 -P 'Goto'
# Core navigation:1 ends here

# [[file:config.org::*Workspaces Assignments][Workspaces Assignments:1]]
set $moveto move container to workspace

set $ws_cmd    "  cmd  "
set $ws_doc    "󰈙  doc  "
set $ws_web    "󰖟  web  "
set $ws_edit   "  edit "
set $ws_video  "  vid  "
set $ws_image  "󰋩  img  "
set $ws_bot    "󰚩  bot  "
set $ws_music  "  music"

# HACK: [all] must come before specific assignments (specific classes overwrite this setting).
for_window [all] title_window_icon yes, $moveto 1, focus
for_window [urgent="latest"] focus

# specific assignments
for_window [class="(?i)cmd"]                     $moveto $ws_cmd,   focus
for_window [class="(?i)zathura"]                 $moveto $ws_doc,   focus
for_window [class="(?i)emacs|(?i)eclipse"]       $moveto $ws_edit,  focus
for_window [class="(?i)firefox"]                 $moveto $ws_web,   focus

for_window [class="(?i)mpv"]                     $moveto $ws_video, focus
for_window [class="(?i)nsxiv"]                   $moveto $ws_image, focus
for_window [class="(?i)firefox" title="ChatGPT"] $moveto $ws_bot,    focus
for_window [class="(?i)firefox" title="Spotify"] $moveto $ws_music, focus
# Workspaces Assignments:1 ends here

# [[file:config.org::*Using main][Using main:1]]
workspace $ws_cmd   output primary
workspace $ws_doc   output primary
workspace $ws_web   output primary
workspace $ws_edit  output primary
workspace $ws_video output primary
workspace $ws_image output primary
workspace $ws_bot    output primary
workspace $ws_music output primary
workspace 1 output primary
workspace 2 output primary
workspace 3 output primary
workspace 4 output primary
# Using main:1 ends here

# [[file:config.org::*App navigation bindings][App navigation bindings:1]]
bindsym $mod+1       workspace 1
bindsym $mod+2       workspace 2
bindsym $mod+3       workspace 3
bindsym $mod+4       workspace 4
bindsym $mod+shift+1 $moveto 1; workspace 1
bindsym $mod+shift+2 $moveto 2; workspace 2
bindsym $mod+shift+3 $moveto 3; workspace 3
bindsym $mod+shift+4 $moveto 4; workspace 4
bindsym $mod+c       workspace $ws_cmd
bindsym $mod+shift+c $moveto $ws_cmd; workspace $ws_cmd
bindsym $mod+d       workspace $ws_doc
bindsym $mod+shift+d $moveto $ws_doc; workspace $ws_doc
bindsym $mod+w       workspace $ws_web
bindsym $mod+shift+w $moveto $ws_web; workspace $ws_web
bindsym $mod+e       workspace $ws_edit
bindsym $mod+shift+e $moveto $ws_edit; workspace $ws_edit
bindsym $mod+v       workspace $ws_video
bindsym $mod+shift+v $moveto $ws_video; workspace $ws_video
bindsym $mod+i       workspace $ws_image
bindsym $mod+shift+i $moveto $ws_image; workspace $ws_image
bindsym $mod+b       workspace $ws_bot
bindsym $mod+shift+b $moveto $ws_bot; workspace $ws_bot
bindsym $mod+m       workspace $ws_music
bindsym $mod+shift+m $moveto $ws_music; workspace $ws_music
# App navigation bindings:1 ends here

# [[file:config.org::*Open app keybindings][Open app keybindings:1]]
set $open <open> \
│ editor \
│ ^editor-everywhere \
│ cmd \
│ web \
│ docs \
│ music \
│ images \
│ [s] passwds \
│ processes \
│ videos \
│ ^mixer \
│ networks \
│ bot

bindsym $mod+o mode "$open"
mode "$open" {
  bindsym $mod+c exec \
    i3-msg '[class="(?i)cmd"] focus' \
    || alacritty --class cmd -T cmd -e tmux new-session -A -s cmd & \
    ; mode "default"

  bindsym $mod+d exec \
    xdg-open "$(fd --extension pdf . ~/Documents/uni/cs | $rofi)" & \
    ; mode "default"

  bindsym $mod+shift+e --release exec \
    emacsclient --execute--eval '(emacs-everywhere)' & \
    ; mode "default"

  bindsym $mod+e exec \
    i3-msg '[class=(?i)emacs] focus' \
    || emacsclient --reuse-frame \
    || emacs --daemon & \
    ; mode "default"

  bindsym $mod+w exec \
    i3-msg '[class=(?i)firefox] focus' \
    || firefox & \
    ; mode "default"

  bindsym $mod+v exec \
    i3-msg '[class=(?i)mpv] focus' \
    || mpv $(xclip -o) & \
    ; mode "default"

  bindsym $mod+i exec \
    i3-msg '[class="(?i)nsxiv"] focus'\
    || nsxiv & \
    ; mode "default"

  bindsym $mod+s exec\
    i3-msg '[class="(?i)keepassxc"] focus"]' \
    || keepassxc & \
    ; mode "default"

  # bindsym $mod+m exec \
  #   i3-msg '[class="(?i)ncmpcpp"] focus' \
  #   || alacritty --class 'ncmpcpp' -T ncmpcpp -e ncmpcpp & \
  #   ; mode "default"

    bindsym $mod+m exec \
    i3-msg '[class="(?i)firefox" title="Spotify"] focus' \
    || firefox --new-window https://open.spotify.com \
    ; mode "default"

  bindsym $mod+shift+m exec \
    i3-msg '[class="(?i)pulsemixer"] focus' \
    || alacritty --class 'pulsemixer' -T 'audio' -e pulsemixer & \
    ; mode "default"

  bindsym $mod+b exec \
    i3-msg '[class="(?i)firefox" title="ChatGPT"] focus' \
    || firefox --new-window https://chat.openai.com \
    ; mode "default"

  bindsym $mod+p exec \
    i3-msg '[class="(?i)htop"] focus'\
    || alacritty --class 'htop' -T 'htop' -e htop --tree & \
    ; mode "default"

  bindsym $mod+n exec \
    i3-msg '[class="(?i)nmtui"] focus' \
    || alacritty --class 'nmtui' -T 'nmtui' -e nmtui & \
    ; mode "default"

  bindsym Escape mode "default"
}
# Open app keybindings:1 ends here

# [[file:config.org::*Leader][Leader:1]]
bindsym $mod+space mode "$leader"
set $leader <leader> \
│ keyboard+ \
│ timer+ \
│ powermenu+ \
│ menus+ \
│ startup

mode "$leader" {
  bindsym $mod+k mode "$keyboard"
  bindsym $mod+p mode "$powermenu"
  bindsym $mod+t mode "$timer"
  bindsym $mod+m mode "$menus"
  bindsym $mod+s exec ~/.config/bin/startup;          mode "default"
  bindsym Escape mode "default"
}
# Leader:1 ends here

# [[file:config.org::*Keyboard layout][Keyboard layout:1]]
set $keyboard <keyboard> \
│ dvorak \
│ ch \
│ us

mode "$keyboard" {
  bindsym $mod+d      exec setxkbmap us dvorak; mode "default"
  bindsym $mod+c      exec setxkbmap ch;        mode "default"
  bindsym $mod+u      exec setxkbmap us;        mode "default"
  bindsym Escape mode "default"
}
# Keyboard layout:1 ends here

# [[file:config.org::*Powermenu][Powermenu:1]]
set $powermenu <powermenu> \
│ restart-i3 \
│ ^reboot \
│ lock \
│ screen-off \
│ poweroff \
│ exit \
│ hibernate \

mode "$powermenu" {
  bindsym $mod+r       exec i3-msg restart;                                mode "default"
  bindsym $mod+e       i3-msg exit;                                        mode "default"
  bindsym $mod+shift+r exec systemctl reboot;                              mode "default"
  bindsym $mod+h       exec systemctl hibernate;                           mode "default"
  bindsym $mod+l       exec i3lock -e --color 002b36 && systemctl suspend; mode "default"
  bindsym $mod+s       exec xset dpms force off;                           mode "default"
  bindsym $mod+p       exec systemctl poweroff;                            mode "default"
  bindsym Escape mode "default"
}
# Powermenu:1 ends here

# [[file:config.org::*Timer][Timer:1]]
set $timer <timer> \
│ toggle \
│ reset \
│ stopwatch \
│ interval: 60m \
│ ^interval: 60/5m \
│ prompt \
│ [1-9] timer: *10m

mode "$timer" {
  bindsym $mod+t       exec ~/.config/bin/timer toggle;                      mode "default"
  bindsym $mod+r       exec ~/.config/bin/timer reset;                       mode "default"
  bindsym $mod+s       exec ~/.config/bin/timer start;                       mode "default"
  bindsym $mod+i       exec ~/.config/bin/timer --frequency=1m start 60m 0m; mode "default"
  bindsym $mod+shift+i exec ~/.config/bin/timer start 60m 5m;                mode "default"
  bindsym $mod+1       exec ~/.config/bin/timer start 10m;                   mode "default"
  bindsym $mod+2       exec ~/.config/bin/timer start 20m;                   mode "default"
  bindsym $mod+3       exec ~/.config/bin/timer start 30m;                   mode "default"
  bindsym $mod+4       exec ~/.config/bin/timer start 40m;                   mode "default"
  bindsym $mod+5       exec ~/.config/bin/timer start 50m;                   mode "default"
  bindsym $mod+6       exec ~/.config/bin/timer start 60m;                   mode "default"
  bindsym $mod+7       exec ~/.config/bin/timer start 70m;                   mode "default"
  bindsym $mod+8       exec ~/.config/bin/timer start 80m;                   mode "default"
  bindsym $mod+9       exec ~/.config/bin/timer start 90m;                   mode "default"
  bindsym Escape mode "default"
}
# Timer:1 ends here

# [[file:config.org::*Menus][Menus:1]]
set $menus <menus> \
│ audio \
│ outputs \
│ [^o] layouts \
│ btconnect \
│ process-kill \
│ screenshot \

mode "$menus" {
  bindsym $mod+a       exec ~/.config/bin/audio-menu;       mode "default"
  bindsym $mod+o       exec ~/.config/bin/output-menu;      mode "default"
  bindsym $mod+shift+o exec ~/.config/bin/layout-menu;      mode "default"
  bindsym $mod+s       exec ~/.config/bin/screenshot-menu;  mode "default"
  bindsym $mod+b       exec ~/.config/bin/bluetooth-menu;   mode "default"
  bindsym $mod+p       exec ~/.config/bin/killprocess-menu; mode "default"
  bindsym Escape mode "default"
}
# Menus:1 ends here

