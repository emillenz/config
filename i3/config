# [[file:config.org::*Abbreviations of long commands][Abbreviations of long commands:1]]
set $rofi rofi -dmenu -i -no-custom -p ' '
set $esc mode "default"
set $bin ~/.config/bin
set $mv move container to workspace
set $map bindsym
# Abbreviations of long commands:1 ends here

# [[file:config.org::*Startup automation][Startup automation:1]]
exec --no-startup-id $bin/startup
# Startup automation:1 ends here

# [[file:config.org::*Options][Options:1]]
workspace_auto_back_and_forth no
workspace_layout tabbed
force_focus_wrapping no
default_orientation horizontal
default_border pixel 1
hide_edge_borders smart
title_align left
font pango: Iosevka Comfy 10
focus_on_window_activation focus
# Options:1 ends here

# [[file:config.org::*Modkey][Modkey:1]]
set $mod Mod4
# Modkey:1 ends here

# [[file:config.org::*Mouse][Mouse:1]]
floating_modifier $mod
$map --release button2 kill
$map --whole-window $mod+button2 floating toggle
# Mouse:1 ends here

# [[file:config.org::*System & Media controls][System & Media controls:1]]
$map XF86MonBrightnessDown exec sudo light -U 5 && notify-send "󰃟 Light" "$(light)%"
$map XF86MonBrightnessUp   exec sudo light -A 5 && notify-send "󰃟 Light" "$(light)%"
$map XF86Display           exec $bin/output_select
$map XF86ScreenSaver       exec xset dpms force off
$map XF86Sleep             exec i3lock -e --color 002b36 && systemctl suspend

$map XF86AudioPlay         exec playerctl play
$map XF86AudioPause        exec playerctl pause
$map XF86AudioNext         exec playerctl next
$map XF86AudioPrev         exec playerctl previous
$map XF86AudioRaiseVolume  exec pactl set-sink-volume @DEFAULT_SINK@ +5% && notify-send " Vol [$(pactl get-sink-mute @DEFAULT_SINK@)]" "$(pactl get-sink-volume @DEFAULT_SINK@ | rg -o '\d+%' | head -n 1)"
$map XF86AudioLowerVolume  exec pactl set-sink-volume @DEFAULT_SINK@ -5% && notify-send " Vol [$(pactl get-sink-mute @DEFAULT_SINK@)]" "$(pactl get-sink-volume @DEFAULT_SINK@ | rg -o '\d+%' | head -n 1)"
$map XF86AudioMute         exec pactl set-sink-mute @DEFAULT_SINK@ toggle && notify-send " Mute toggle" "$(pactl get-sink-mute @DEFAULT_SINK@)"
# System & Media controls:1 ends here

# [[file:config.org::*System & Media controls][System & Media controls:2]]
$map Print             exec $bin/screenshot
$map $mod+backslash    exec playerctl play-pause
$map $mod+bracketright exec playerctl next
$map $mod+bracketleft  exec playerctl previous
$map $mod+equal        exec pactl set-sink-volume @DEFAULT_SINK@ +5% && notify-send " Vol [$(pactl get-sink-mute @DEFAULT_SINK@)]" "$(pactl get-sink-volume @DEFAULT_SINK@ | rg -o '\d+%' | head -n 1)"
$map $mod+minus        exec pactl set-sink-volume @DEFAULT_SINK@ -5% && notify-send " Vol [$(pactl get-sink-mute @DEFAULT_SINK@)]" "$(pactl get-sink-volume @DEFAULT_SINK@ | rg -o '\d+%' | head -n 1)"
$map $mod+0            exec pactl set-sink-mute @DEFAULT_SINK@ toggle && notify-send " Mute toggle" "$(pactl get-sink-mute @DEFAULT_SINK@)"
# System & Media controls:2 ends here

# [[file:config.org::*Core navigation][Core navigation:1]]
$map $mod+j          focus prev
$map $mod+shift+j    move left
$map $mod+k          focus next
$map $mod+shift+k    move right
$map $mod+q          kill
$map $mod+f          exec rofi -show drun
$map $mod+g          exec rofi -show window
$map $mod+semicolon  exec rofi -show run
$map $mod+t          layout toggle tabbed splith
$map $mod+Return     move workspace to output next
# Core navigation:1 ends here

# [[file:config.org::*Workspaces Assignments][Workspaces Assignments:1]]
set $ws_cmd    "  cmd  "
set $ws_doc    "󰈙  doc  "
set $ws_web    "󰖟  web  "
set $ws_edit   "  edit "
set $ws_vid    "  vid  "
set $ws_img    "󰋩  img  "
set $ws_bot    "󰚩  bot  "
set $ws_music  "  music"

# HACK :: order of these assingments are relevant: abstract -> detail.
for_window [all] title_window_icon yes, $mv 1, focus
for_window [urgent="latest"] focus

for_window [class="(?i)cmd"]                         $mv $ws_cmd,   focus
for_window [class="(?i)zathura"]                     $mv $ws_doc,   focus
for_window [class="(?i)emacs|(?i)eclipse"]           $mv $ws_edit,  focus
for_window [class="(?i)firefox"]                     $mv $ws_web,   focus
for_window [class="(?i)mpv"]                         $mv $ws_vid,   focus
for_window [class="(?i)nsxiv"]                       $mv $ws_img,   focus
for_window [class="(?i)firefox" title="(?i)ChatGPT"] $mv $ws_bot,   focus
for_window [class="(?i)firefox" title="(?i)Spotify"] $mv $ws_music, focus
# Workspaces Assignments:1 ends here

# [[file:config.org::*Using main][Using main:1]]
workspace $ws_cmd   output primary
workspace $ws_doc   output primary
workspace $ws_web   output primary
workspace $ws_edit  output primary
workspace $ws_vid   output primary
workspace $ws_img   output primary
workspace $ws_bot   output primary
workspace $ws_music output primary
workspace 1         output primary
workspace 2         output primary
workspace 3         output primary
workspace 4         output primary
# Using main:1 ends here

# [[file:config.org::*App navigation bindings][App navigation bindings:1]]
$map $mod+1       workspace 1
$map $mod+shift+1 $mv 1; workspace 1
$map $mod+2       workspace 2
$map $mod+shift+2 $mv 2; workspace 2
$map $mod+3       workspace 3
$map $mod+shift+3 $mv 3; workspace 3
$map $mod+4       workspace 4
$map $mod+shift+4 $mv 4; workspace 4

$map $mod+c       workspace $ws_cmd
$map $mod+shift+c $mv $ws_cmd; workspace $ws_cmd
$map $mod+d       workspace $ws_doc
$map $mod+shift+d $mv $ws_doc; workspace $ws_doc
$map $mod+w       workspace $ws_web
$map $mod+shift+w $mv $ws_web; workspace $ws_web
$map $mod+e       workspace $ws_edit
$map $mod+shift+e $mv $ws_edit; workspace $ws_edit
$map $mod+v       workspace $ws_vid
$map $mod+shift+v $mv $ws_vid; workspace $ws_vid
$map $mod+i       workspace $ws_img
$map $mod+shift+i $mv $ws_img; workspace $ws_img
$map $mod+b       workspace $ws_bot
$map $mod+shift+b $mv $ws_bot; workspace $ws_bot
$map $mod+m       workspace $ws_music
$map $mod+shift+m $mv $ws_music; workspace $ws_music
# App navigation bindings:1 ends here

# [[file:config.org::*Open app keybindings][Open app keybindings:1]]
set $open <open> \
│ editor \
│ ^editor-everywhere \
│ cmd \
│ web \
│ docs \
│ music \
│ images \
│ [s] passwds \
│ processes \
│ videos \
│ ^mixer \
│ networks \
│ bot

$map $mod+o mode "$open"
mode "$open" {
  $map $mod+c                 exec alacritty --class cmd -T cmd -e tmux new-session -A -s cmd; $esc
  $map $mod+d                 exec xdg-open "$(fd --extension pdf . ~/Documents/uni/cs | $rofi)"; $esc
  $map $mod+shift+e --release exec emacsclient --execute--eval '(emacs-everywhere)'; $esc
  $map $mod+e                 exec emacsclient --reuse-frame || emacs --daemon; $esc
  $map $mod+w                 exec firefox; $esc
  $map $mod+v                 exec mpv $(xclip -o); $esc
  $map $mod+i                 exec nsxiv; $esc
  $map $mod+s                 exec keepassxc; $esc
  $map $mod+m                 exec firefox --new-window https://open.spotify.com; $esc
  $map $mod+shift+m           exec alacritty --class 'pulsemixer' -T 'audio' -e pulsemixer; $esc
  $map $mod+b                 exec firefox --new-window https://chat.openai.com; $esc
  $map $mod+p                 exec alacritty --class 'htop' -T 'htop' -e htop --tree; $esc
  $map $mod+n                 exec alacritty --class 'nmtui' -T 'nmtui' -e nmtui; $esc
  $map Escape $esc
}
# Open app keybindings:1 ends here

# [[file:config.org::*Leader][Leader:1]]
$map $mod+space mode "$leader"
set $leader <leader> \
│ keyboard+ \
│ powermenu+ \
│ menus+ \
│ startup

mode "$leader" {
  $map $mod+k mode "$keyboard"
  $map $mod+p mode "$powermenu"
  $map $mod+m mode "$menus"
  $map $mod+s exec $bin/startup; $esc
  $map Escape $esc
}
# Leader:1 ends here

# [[file:config.org::*Powermenu][Powermenu:1]]
set $powermenu <powermenu> \
│ restart-i3 \
│ ^reboot \
│ lock \
│ screen-off \
│ poweroff \
│ exit \
│ hibernate \

mode "$powermenu" {
  $map $mod+r       exec i3-msg restart;                                $esc
  $map $mod+e       exec i3-msg exit;                                   $esc
  $map $mod+shift+r exec systemctl reboot;                              $esc
  $map $mod+h       exec systemctl hibernate;                           $esc
  $map $mod+l       exec i3lock -e --color 002b36 && systemctl suspend; $esc
  $map $mod+s       exec xset dpms force off;                           $esc
  $map $mod+p       exec systemctl poweroff;                            $esc
  $map Escape $esc
}
# Powermenu:1 ends here

# [[file:config.org::*Menus][Menus:1]]
set $menus <menus> \
│ audio \
│ outputs \
│ [^o] layouts \
│ btconnect \
│ process-kill \
│ screenshot \

mode "$menus" {
  $map $mod+a       exec $bin/audio-menu;       $esc
  $map $mod+o       exec $bin/output-menu;      $esc
  $map $mod+shift+o exec $bin/layout-menu;      $esc
  $map $mod+s       exec $bin/screenshot-menu;  $esc
  $map $mod+b       exec $bin/bluetooth-menu;   $esc
  $map $mod+p       exec $bin/killprocess-menu; $esc
  $map Escape $esc
}
# Menus:1 ends here

