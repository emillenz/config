# [[file:config.org::*Startup automation][Startup automation:1]]
exec_always --no-startup-id "~/.config/bin/startup"
# Startup automation:1 ends here

# [[file:config.org::*Options][Options:1]]
workspace_auto_back_and_forth no
workspace_layout tabbed
force_focus_wrapping no
default_orientation horizontal
default_border pixel 1
hide_edge_borders smart
title_align left
font pango: Terminus 8
for_window [all] title_window_icon yes
for_window [urgent="latest"] focus

# used for finding files later (1:1 expanded during config parsing)
set $rofi rofi -dmenu -i -no-custom -p ' '
# Options:1 ends here

# [[file:config.org::*Modkey][Modkey:1]]
set $mod Mod4
# Modkey:1 ends here

# [[file:config.org::*Mouse][Mouse:1]]
floating_modifier $mod
bindsym --release button2 kill
bindsym --whole-window $mod+button2 floating toggle
bindsym button4 nop
bindsym button5 nop
# Mouse:1 ends here

# [[file:config.org::*System controls][System controls:1]]
bindsym XF86MonBrightnessDown exec sudo light -U 5
bindsym XF86MonBrightnessUp   exec sudo light -A 5
bindsym XF86Display           exec ~/.config/bin/output_select
bindsym XF86ScreenSaver       exec xset dpms force off
bindsym XF86Sleep             exec i3lock -e --color 002b36 && systemctl suspend

bindsym XF86AudioPlay         exec playerctl play
bindsym XF86AudioPause        exec playerctl pause
bindsym XF86AudioNext         exec playerctl next
bindsym XF86AudioPrev         exec playerctl previous
bindsym XF86AudioRaiseVolume  exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume  exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute         exec pactl set-sink-mute @DEFAULT_SINK@ toggle
# System controls:1 ends here

# [[file:config.org::*System controls][System controls:2]]
bindsym Print                 exec ~/.config/bin/screenshot
bindsym $mod+backslash        exec playerctl play-pause
bindsym $mod+bracketright     exec playerctl next
bindsym $mod+bracketleft      exec playerctl previous
bindsym $mod+equal            exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym $mod+minus            exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym $mod+shift+backslash  exec pactl set-sink-mute @DEFAULT_SINK@ toggle
# System controls:2 ends here

# [[file:config.org::*Core navigation][Core navigation:1]]
bindsym $mod+j          focus prev
bindsym $mod+shift+j    move left
bindsym $mod+k          focus next
bindsym $mod+shift+k    move right
bindsym $mod+q          kill
bindsym $mod+f          exec rofi -show drun
bindsym $mod+g          exec rofi -show window
bindsym $mod+semicolon  exec rofi -show run
bindsym $mod+Tab        layout toggle tabbed splith
bindsym $mod+m          exec i3-input -F 'mark %s' -l 1 -P 'Mark:'
bindsym $mod+apostrophe exec i3-input -F '[con_mark="%s"] focus' -l 1 -P 'Goto'
# Core navigation:1 ends here

# [[file:config.org::*Workspaces Assignments][Workspaces Assignments:1]]
set $ws_cmd     cmd
set $ws_doc    󰈙 doc
set $ws_web    󰖟 web
set $ws_edit    edit

set $ws_video   video
set $ws_images 󰋩 images

for_window [class="(?i)cmd"] move container to workspace $ws_cmd
for_window [class="(?i)zathura"] move container to workspace $ws_doc
for_window [class="(?i)firefox"] move container to workspace $ws_web
for_window [class="(?i)macs|(?i)Eclipse"] move container to workspace $ws_edit

for_window [class="(?i)mpv"] move container to workspace $ws_video
for_window [class="(?i)nsxiv"] move container to workspace $ws_images

# all other's to unnamed ws -> 1
assign [all] 1
# Workspaces Assignments:1 ends here

# [[file:config.org::*App navigation bindings][App navigation bindings:1]]
bindsym $mod+Return    move workspace to output next
bindsym $mod+1         workspace 1
bindsym $mod+2         workspace 2
bindsym $mod+3         workspace 3
bindsym $mod+4         workspace 4
bindsym $mod+shift+1   move container to workspace 1; workspace 1
bindsym $mod+shift+2   move container to workspace 2; workspace 2
bindsym $mod+shift+3   move container to workspace 3; workspace 3
bindsym $mod+shift+4   move container to workspace 4; workspace 4
bindsym $mod+c workspace $ws_cmd
bindsym $mod+shift+c move container to workspace $ws_cmd
bindsym $mod+d workspace $ws_doc
bindsym $mod+shift+d move container to workspace $ws_doc
bindsym $mod+w workspace $ws_web
bindsym $mod+shift+w move container to workspace $ws_web
bindsym $mod+e workspace $ws_edit
bindsym $mod+shift+e move container to workspace $ws_edit
bindsym $mod+v workspace $ws_video
bindsym $mod+shift+v move container to workspace $ws_video
bindsym $mod+i workspace $ws_images
bindsym $mod+shift+i move container to workspace $ws_images
bindsym $mod+z restart
# App navigation bindings:1 ends here

# [[file:config.org::*Open app keybindings][Open app keybindings:1]]
set $tab <tab> \
│ editor \
│ cmd \
│ web \
│ doc-reader \
│ music-player \
│ image-viewer \
│ [s] passwds \
│ processes \
│ video-player \
│ ^mixer \
│ networks

bindsym $mod+t mode "$tab"
mode "$tab" {
  bindsym c exec \
    i3-msg '[class="cmd"] focus' \
    || alacritty --class cmd -T cmd -e tmux new-session -A -s cmd & \
    ; mode "default"

  bindsym d exec \
    xdg-open "$(fd --relative-path --extension pdf . ~/Documents/uni/cs | $rofi)" & \
    ; mode "default"

  bindsym --release shift+e exec \
    doom +everywhere & \
    ; mode "default"

  bindsym e exec \
    i3-msg '[class=emacs] focus' \
    || emacsclient --reuse-frame \
    || emacs --daemon --execute '(doom/reload)' & \
    ; mode "default"

  bindsym w exec \
    i3-msg '[class=firefox] focus' \
    || firefox & \
    ; mode "default"

  bindsym m exec \
    i3-msg '[class="ncmpcpp"] focus' \
    || alacritty --class 'ncmpcpp' -T ncmpcpp -e ncmpcpp & \
    ; mode "default"

  bindsym v exec \
    i3-msg '[class=mpv] focus' \
    || mpv $(xclip -o) & \
    ; mode "default"

  bindsym i exec \
    i3-msg '[class="nsxiv"] focus'\
    || nsxiv & \
    ; mode "default"

  bindsym s exec\
    i3-msg '[class="keepassxc"] focus"]' \
    || keepassxc & \
    ; mode "default"

  bindsym shift+m exec \
    i3-msg '[class="pulsemixer"] focus' \
    || alacritty --class 'pulsemixer' -T 'audio' -e pulsemixer & \
    ; mode "default"

  bindsym p exec \
    i3-msg '[class="htop"] focus'\
    || alacritty --class 'htop' -T 'htop' -e htop --tree & \
    ; mode "default"

  bindsym n exec \
    i3-msg '[class="nmtui"] focus' \
    || alacritty --class 'nmtui' -T 'nmtui' -e nmtui & \
    ; mode "default"

  bindsym Escape mode "default"
}
# Open app keybindings:1 ends here

# [[file:config.org::*Leader][Leader:1]]
bindsym $mod+space mode "$leader"
set $leader <leader> \
│ audio \
│ outputs \
│ [^o] layouts \
│ btconnect \
│ process-kill \
│ find+ \
│ keyboard+ \
│ timer+ \
│ sysact+ \
│ ^screenshot+


mode "$leader" {
  bindsym a       exec ~/.config/bin/mini-audio; mode "default"
  bindsym o       exec ~/.config/bin/mini-output; mode "default"
  bindsym shift+o exec ~/.config/bin/mini-layout; mode "default"
  bindsym shift+s exec ~/.config/bin/mini-screenshot; mode "default"
  bindsym b       exec ~/.config/bin/mini-bluetooth; mode "default"
  bindsym p       exec ~/.config/bin/mini-killprocess; mode "default"

  bindsym f      mode "$find"
  bindsym k      mode "$keyboard"
  bindsym s      mode "$sysact"
  bindsym t      mode "$timer"
  bindsym Escape mode "default"
}
# Leader:1 ends here

# [[file:config.org::*Keyboard layout][Keyboard layout:1]]
set $keyboard <keyboard> \
│ dvorak \
│ ch \
│ us

mode "$keyboard" {
  bindsym d      exec setxkbmap us dvorak; mode "default"
  bindsym c      exec setxkbmap ch;        mode "default"
  bindsym u      exec setxkbmap us;        mode "default"
  bindsym Escape                           mode "default"
}
# Keyboard layout:1 ends here

# [[file:config.org::*System Action][System Action:1]]
set $sysact <sysact> \
│ restart-i3 \
│ ^reboot \
│ lock \
│ screen-off \
│ poweroff \
│ exit \
│ hibernate \
│ ^startup

mode "$sysact" {
  bindsym r       restart;                                              mode "default"
  bindsym e       exit;                                                 mode "default"
  bindsym shift+r exec syste                            mctl reboot;    mode "default"
  bindsym h       exec syste                            mctl hibernate; mode "default"
  bindsym l       exec i3lock -e --color 002b36 && systemctl suspend;   mode "default"
  bindsym s       exec xset dp                          ms force off;   mode "default"
  bindsym p       exec syste                            mctl poweroff;  mode "default"
  bindsym shift+s exec ~/.config/bin/startup;                           mode "default"
  bindsym Escape                                        mode "default"
}
# System Action:1 ends here

# [[file:config.org::*Timer][Timer:1]]
set $timer <timer> \
│ toggle \
│ reset \
│ stopwatch \
│ interval: 60/5 \
│ ^interval: 30/5 \
│ prompt \
│ [1-9] timer: *10m

mode "$timer" {
  bindsym t       exec ~/.config/bin/timer toggle;       mode "default"
  bindsym r       exec ~/.config/bin/timer reset;        mode "default"
  bindsym s       exec ~/.config/bin/timer start;        mode "default"
  bindsym i       exec ~/.config/bin/timer start 60m 5m; mode "default"
  bindsym shift+i exec ~/.config/bin/timer start 30m 5m; mode "default"
  bindsym 1       exec ~/.config/bin/timer start 10m;    mode "default"
  bindsym 2       exec ~/.config/bin/timer start 20m;    mode "default"
  bindsym 3       exec ~/.config/bin/timer start 30m;    mode "default"
  bindsym 4       exec ~/.config/bin/timer start 40m;    mode "default"
  bindsym 5       exec ~/.config/bin/timer start 50m;    mode "default"
  bindsym 6       exec ~/.config/bin/timer start 60m;    mode "default"
  bindsym 7       exec ~/.config/bin/timer start 70m;    mode "default"
  bindsym 8       exec ~/.config/bin/timer start 80m;    mode "default"
  bindsym 9       exec ~/.config/bin/timer start 90m;    mode "default"
  bindsym Escape                                         mode "default"
}
# Timer:1 ends here

# [[file:config.org::*Find][Find:1]]
set $find <find> \
│ pdf \
│ uni

mode "$find" {
  bindsym p exec xdg-open "$(fd --relative-path --extension pdf | $rofi)"; mode "default"
  bindsym u exec xdg-open "$(fd --relative-path --extension pdf . ~/Documents/uni/cs | $rofi)"; mode "default"
  bindsym Escape mode "default"
}
# Find:1 ends here

# [[file:config.org::*Solarized dark][Solarized dark:1]]
set $backg      #002b36
set $foreg      #839496
set $main       #268BD2
set $yellow     #B58900
set $orange     #CB4B16
set $red        #DC322F
set $purple     #6C71C4
set $magenta    #d33682
set $blue       #268BD2
set $cyan       #2AA198
set $green      #859900
# Solarized dark:1 ends here

# [[file:config.org::*Set theme][Set theme:1]]
# class                 border  backg   text    indicator child_border
client.focused          $main   $main   $backg  $foreg    $main
client.focused_inactive $backg  $foreg  $backg  $backg    $backg
client.unfocused        $backg  $backg  $foreg  $backg    $backg
client.urgent           $red    $red    $backg  $backg    $backg
client.placeholder      $backg  $backg  $foreg  $backg    $backg
client.background       $backg
# Set theme:1 ends here
