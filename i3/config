set $foreg      #839496
set $main       #268BD2
set $yellow     #B58900
set $orange     #CB4B16
set $red        #DC322F
set $purple     #6C71C4
set $magenta    #d33682
set $blue       #268BD2
set $cyan       #2AA198
set $green      #859900
# Solarized dark:1 ends here

