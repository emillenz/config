#+title:  I3-status config
#+author: Emil Lenz
#+email:  emillenz@protonmail.com
#+date:   2024-01-19
#+info:   Minimalist setup, as the bar i only used as a mode indicator.

general {
  colors = true
  interval = 5
  color_good = "#819500"
  color_degraded = "#D56500"
  color_bad = "#F23749"
  separator = "|"
}

order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
order += "volume master"
order += "tztime local"


wireless _first_ {
  format_up = "wifi: %essid, %quality, "
  format_down = "wifi: nil"
}

ethernet _first_ {
  format_up = "eth: %speed"
  format_down = "eth: nil"
}

battery all {
  format = "bat: %status, %percentage %emptytime"
  integer_battery_capacity = true
  format_down = "bat: nil"
  status_chr = up
  status_bat = down
  status_unk = nil
  status_full = full
  low_threshold = 20
  threshold_type = time
}

volume master {
  format = "vol: %volume"
  format_muted = "vol: mut [%volume]"
  device = "default"
  mixer = "Master"
  mixer_idx = 0
}

tztime local {
  format = "%Y-%m-%d %H:%M"
}
