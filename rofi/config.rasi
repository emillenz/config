//         bg:             #000000;
//         border:         #646464;
//         foreground:     #ffffff;
//         selected:       #2f447f;
//         active:         #f78fe7;
//         urgent:         #fec43f;
//         prompt:         #6ae4b9;
// }

// modus-operandi theme ::
* {
        bg:             #ffffff;
        border:         #595959;
        foreground:     #000000;
        selected:       #c0deff;
        active:         #0031a9;
        urgent:         #a60000;
        prompt:         #005f5f;
}
