set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
set window-title-basename true
set statusbar-basename true
set font "Iosevka Nerd Font 10"
set adjust-open "best-fit"
set window-title-page true
set render-loading true
set recolor-keephue true

# more ergonomic top layer mappings
map u scroll half-up
map d scroll half-down
map i jumplist forward
map o jumplist backward
map z snap_to_page # vim
map v toggle_page_mode # mnemonic: split
map = zoom in
map - zoom out
map w adjust_window best-fit # mnemonic: width/window
map W adjust_window width # mnemonic: width/window
unmap a

