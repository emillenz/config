set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
set window-title-basename true
set statusbar-basename true
set font "Iosevka Nerd Font 10"
set adjust-open "width"
set window-title-page true
set recolor true
set render-loading true
set recolor-keephue true

map u scroll half-up
map d scroll half-down
map C-u scroll half-up
map C-d scroll half-down
map C-f Page Up
map C-b Page Down
map a adjust_window best-fit
map A adjust_window width
map z snap_to_page
map t toggle_page_mode
map r reload
map R rotate
map = zoom in
map - zoom out
map i recolor
map p print

# solarized dark
set notification-error-bg       "#98a8a8"
set notification-error-fg       "#DC322F"
set notification-warning-bg     "#98a8a8"
set notification-warning-fg     "#DC322F"
set notification-bg             "#98a8a8"
set notification-fg             "#B58900"
set completion-group-bg         "#002B36"
set completion-group-fg         "#98a8a8"
set completion-bg               "#002B36"
set completion-fg               "#98a8a8"
set completion-highlight-bg     "#98a8a8"
set completion-highlight-fg     "#268BD2"
set index-bg                    "#002B36"
set index-fg                    "#93A1A1"
set index-active-bg             "#98a8a8"
set index-active-fg             "#268BD2"
set inputbar-bg                 "#98a8a8"
set inputbar-fg                 "#268BD2"
set statusbar-bg                "#002B36"
set statusbar-fg                "#93A1A1"
set highlight-color             "#98a8a8"
set highlight-active-color      "#268BD2"
set default-bg                  "#002B36"
set default-fg                  "#93A1A1"
set recolor-lightcolor          "#002B36"
set recolor-darkcolor           "#93A1A1"
set render-loading-fg           "#002B36"
set render-loading-bg           "#002B36"
