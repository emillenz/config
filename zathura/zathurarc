set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
set window-title-basename true
set statusbar-basename true
set font "Iosevka Nerd Font 10"
set adjust-open "width"
set window-title-page true
set render-loading true
set recolor true
set recolor-keephue true

map u scroll half-up
map d scroll half-down
map C-u scroll half-up
map C-d scroll half-down
map i jumplist forward
map o jumplist backward
map C-i jumplist forward
map C-o jumplist backward
map z snap_to_page
map t toggle_page_mode
map r reload
map R rotate
map 0 adjust_window best-fit
map = zoom in
map - zoom out
map v recolor

# modus vivendi theme ::
set notification-error-bg       "#303030"
set notification-error-fg       "#ff5f59"
set notification-warning-bg     "#303030"
set notification-warning-fg     "#ff5f59"
set notification-bg             "#303030"
set notification-fg             "#dfcf43"
set completion-group-bg         "#2f447f"
set completion-group-fg         "#ffffff"
set completion-bg               "#303030"
set completion-fg               "#ffffff"
set completion-highlight-bg     "#2f447f"
set completion-highlight-fg     "#ffffff"
set index-bg                    "#000000"
set index-fg                    "#ffffff"
set index-active-bg             "#2f447f"
set index-active-fg             "#ffffff"
set inputbar-bg                 "#303030"
set inputbar-fg                 "#ffffff"
set statusbar-bg                "#303030"
set statusbar-fg                "#ffffff"
